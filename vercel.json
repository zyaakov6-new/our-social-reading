{
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|\\.well-known/|sitemap\\.xml|robots\\.txt|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
